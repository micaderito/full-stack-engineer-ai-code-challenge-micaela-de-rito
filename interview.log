{"event":"pre-tool-use","timestamp":"2026-06-05T15:25:00.635Z","tool_name":"Write","tool_input":{"file_path":"/home/fragnot/Project/full-stack-engineer/src/StratusFabTracker.Tests/StationTests.cs","content":"using StratusFabTracker.Api.Domain;\n\nnamespace StratusFabTracker.Tests;\n\npublic class StationTests\n{\n    [Fact]\n    public void Detailing_advances_to_Cut()\n    {\n        Assert.Equal(Station.Cut, Station.Detailing.Next());\n    }\n\n    [Fact]\n    public void Installed_has_no_next_station()\n    {\n        Assert.Null(Station.Installed.Next());\n    }\n}\n"}}
